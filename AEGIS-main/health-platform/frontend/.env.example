# Backend API URL - set this to your Railway backend URL on Vercel
VITE_API_BASE_URL=https://your-railway-backend-url.railway.app

# Cesium Ion token - get free token from cesium.com
VITE_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# WebSocket URL - same as your Railway backend URL
VITE_WS_URL=wss://your-railway-backend-url.railway.app/ws
